<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect /published/ to Render backend
  RewriteRule ^published/(.*)$ https://creator-backend-ar1g.onrender.com/published/$1 [R=301,L]

  # React Router fallback
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
