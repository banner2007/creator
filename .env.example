# Server Configuration
PORT=3000
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT (Used for additional backend token security if needed)
JWT_SECRET=super-secret-jwt-key

# Kie.ai API Credentials (Used for AI Image Generation)
KIE_API_KEY=your-kie-ai-api-key

# Make.com Automation Webhooks
MAKE_PUBLISH_WEBHOOK_URL=https://hook.us1.make.com/your-publish-hook-id
MAKE_LEAD_WEBHOOK_URL=https://hook.us1.make.com/your-lead-hook-id
